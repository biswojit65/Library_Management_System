# ─── Database ─────────────────────────────────────────────────────────────────
DB_NAME=library_db
DB_USER=library_user
DB_PASSWORD=change_me_in_production

# ─── Redis ────────────────────────────────────────────────────────────────────
# Leave REDIS_PASSWORD blank if Redis has no auth (default for dev).
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_random_32_plus_char_secret
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=168h

# ─── Frontend build (Docker only) ─────────────────────────────────────────────
# In Docker the frontend nginx container proxies /api/ → backend, so /api/v1
# is correct. For local dev without Docker use http://localhost:8080/api/v1.
VITE_API_URL=/api/v1
